---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';
import { getTranslations, type Language } from '../../i18n/index.ts';

export const prerender = true;

export async function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = getTranslations(lang as Language);

const titles: Record<string, string> = {
  es: 'Contacto - CONSTRUESCALA',
  en: 'Contact - CONSTRUESCALA',
};

const altTexts: Record<string, string> = {
  es: 'Contacto',
  en: 'Contact',
};

const mapTitles: Record<string, string> = {
  es: 'Ubicación CONSTRUESCALA',
  en: 'CONSTRUESCALA Location',
};
---

<Layout title={titles[lang]} lang={lang as Language}>
  <Navbar lang={lang as Language} />

  <!-- Hero Banner -->
  <section class="relative h-[60vh] min-h-[400px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/about/about-bg.jpg"
        alt={altTexts[lang]}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-negro/80"></div>
    </div>
    <div class="relative z-10 text-center px-6">
      <span class="text-dorado text-sm tracking-widest uppercase font-medium animate-fade-in">{t.contactPage.title}</span>
      <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl font-bold mt-4 animate-fade-up">
        {t.contactPage.heading} <span class="text-dorado italic">{t.contactPage.headingHighlight}</span>
      </h1>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-24 lg:py-32 bg-negro">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Form -->
        <div class="scroll-reveal-left">
          <span class="text-dorado text-sm tracking-widest uppercase font-medium">{t.contactPage.formTitle}</span>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-blanco mt-4 mb-6">
            {t.contactPage.formSubtitle} <span class="text-dorado italic">{t.contactPage.formHighlight}</span>
          </h2>
          <div class="w-16 h-0.5 bg-dorado mb-8"></div>

          <ContactForm lang={lang as Language} />
        </div>

        <!-- Contact Info -->
        <div class="scroll-reveal-right">
          <span class="text-dorado text-sm tracking-widest uppercase font-medium">{t.contactPage.infoTitle}</span>
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-blanco mt-4 mb-6">
            {t.contactPage.infoSubtitle} <span class="text-dorado italic">{t.contactPage.infoHighlight}</span>
          </h2>
          <div class="w-16 h-0.5 bg-dorado mb-8"></div>

          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 border border-gris-borde flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-dorado" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg font-semibold text-blanco mb-1">{t.contactPage.address}</h3>
                <p class="text-gris-claro">Medellin, CL. 52 #49-28<br/>Edificio LA LONJA 8-03</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 border border-gris-borde flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-dorado" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg font-semibold text-blanco mb-1">{t.contactPage.emails}</h3>
                <a href="mailto:ventas@construescala.com" class="text-gris-claro hover:text-dorado transition-colors block">ventas@construescala.com</a>
               <!-- <a href="mailto:construescalasas@gmail.com" class="text-gris-claro hover:text-dorado transition-colors block">construescalasas@gmail.com</a> -->
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 border border-gris-borde flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-dorado" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </div>
              <div>
                <h3 class="font-serif text-lg font-semibold text-blanco mb-1">{t.contactPage.whatsapp}</h3>
                <a href="https://wa.me/573001234567" target="_blank" rel="noopener" class="text-gris-claro hover:text-dorado transition-colors">
                  +57 300 123 4567
                </a>
              </div>
            </div>
          </div>

          <!-- Map -->
          <div class="mt-12 border border-gris-borde overflow-hidden">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3976.5!2d-75.5658!3d6.2442!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNsKwMTQnMzkuMSJOIDc1wrAzMyc1Ni45Ilc!5e0!3m2!1ses!2sco!4v1"
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={mapTitles[lang]}
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer lang={lang as Language} />
</Layout>