---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getTranslations, type Language } from '../../i18n/index.ts';

export const prerender = true;

export async function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = getTranslations(lang as Language);

const titles: Record<string, string> = {
  es: 'Servicios - CONSTRUESCALA',
  en: 'Services - CONSTRUESCALA',
};

const altTexts: Record<string, string> = {
  es: 'Servicios',
  en: 'Services',
};

const images = [
  '/images/services/service-1.jpg',
  '/images/services/service-2.jpg',
  '/images/services/service-3.jpg',
];
---

<Layout title={titles[lang]} lang={lang as Language}>
  <Navbar lang={lang as Language} />

  <!-- Hero Banner -->
  <section class="relative h-[60vh] min-h-[400px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/services/services-bg.jpg"
        alt={altTexts[lang]}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-negro/80"></div>
    </div>
    <div class="relative z-10 text-center px-6">
      <span class="text-dorado text-sm tracking-widest uppercase font-medium animate-fade-in">{t.servicesPage.title}</span>
      <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl font-bold mt-4 animate-fade-up">
        {t.servicesPage.heading} <span class="text-dorado italic">{t.servicesPage.headingHighlight}</span>
      </h1>
    </div>
  </section>

  <!-- Services Detail -->
  <section class="py-24 lg:py-32 bg-negro">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="space-y-32">
        {t.servicesPage.items.map((service, i) => (
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center ${i % 2 === 1 ? 'lg:direction-rtl' : ''}`}>
            <div class={`${i % 2 === 1 ? 'lg:order-2 scroll-reveal-right' : 'scroll-reveal-left'}`}>
              <div class="relative">
                <img
                  src={images[i]}
                  alt={service.title}
                  class="w-full aspect-[4/3] object-cover"
                  loading="lazy"
                />
                <div class="absolute -top-4 -left-4 lg:-top-6 lg:-left-6">
                  <span class="font-serif text-7xl lg:text-9xl font-bold text-dorado/20">{service.number}</span>
                </div>
              </div>
            </div>

            <div class={`${i % 2 === 1 ? 'lg:order-1 scroll-reveal-left' : 'scroll-reveal-right'}`}>
              <span class="text-dorado text-sm tracking-widest uppercase font-medium">{service.subtitle}</span>
              <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-blanco mt-4 mb-6">
                {service.title}
              </h2>
              <div class="w-16 h-0.5 bg-dorado mb-8"></div>
              <p class="text-gris-claro leading-relaxed mb-8">
                {service.description}
              </p>
              
              <ul class="space-y-3 mb-10">
                {service.details.map(detail => (
                  <li class="flex items-center gap-3 text-blanco">
                    <svg class="w-5 h-5 text-dorado shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    {detail}
                  </li>
                ))}
              </ul>

              <a href={`/${lang}/contact`} class="btn-dorado">
                {t.servicesPage.cta}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-negro-suave">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center scroll-reveal">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-blanco mb-6">
        {t.servicesPage.ctaSection.heading}
      </h2>
      <p class="text-gris-claro text-lg mb-8 max-w-2xl mx-auto">
        {t.servicesPage.ctaSection.description}
      </p>
      <a href={`/${lang}/contact`} class="btn-dorado">
        {t.servicesPage.ctaSection.cta}
      </a>
    </div>
  </section>

  <Footer lang={lang as Language} />
</Layout>