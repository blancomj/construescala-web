---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getTranslations, type Language } from '../../i18n/index.ts';

export const prerender = true;

export async function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = getTranslations(lang as Language);

const titles: Record<string, string> = {
  es: 'Nosotros - CONSTRUESCALA',
  en: 'About Us - CONSTRUESCALA',
};

const altTexts: Record<string, string> = {
  es: 'Sobre nosotros',
  en: 'About us',
};
---

<Layout title={titles[lang]} lang={lang as Language}>
  <Navbar lang={lang as Language} />

  <!-- Hero Banner -->
  <section class="relative h-[60vh] min-h-[400px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/about/about-bg.jpg"
        alt={altTexts[lang]}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-negro/80"></div>
    </div>
    <div class="relative z-10 text-center px-6">
      <span class="text-dorado text-sm tracking-widest uppercase font-medium animate-fade-in">{t.about.title}</span>
      <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl font-bold mt-4 animate-fade-up">
        {t.about.heading} <span class="text-dorado italic">{t.about.headingHighlight}</span>
      </h1>
    </div>
  </section>

  <!-- About Text -->
  <section class="py-24 lg:py-32 bg-negro">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="scroll-reveal-left">
          <div class="relative">
            <img
              src="/images/about/about-team.jpg"
              alt={lang === 'es' ? 'Interior elegante' : 'Elegant interior'}
              class="w-full aspect-[4/5] object-cover"
              loading="lazy"
            />
            <div class="absolute -bottom-6 -right-6 w-32 h-32 border-2 border-dorado -z-10"></div>
            <div class="absolute -top-6 -left-6 w-32 h-32 bg-dorado/10 -z-10"></div>
          </div>
        </div>

        <div class="scroll-reveal-right">
          <span class="text-dorado text-sm tracking-widest uppercase font-medium">{t.about.whoWeAre}</span>
          <h2 class="section-title mt-4 mb-8">
            {t.about.subtitle} <span class="text-dorado italic">{t.about.subtitleHighlight}</span>
          </h2>
          <div class="divider-dorado mb-8"></div>
          <p class="text-gris-claro leading-relaxed mb-6">
            {t.about.description1}
          </p>
          <p class="text-gris-claro leading-relaxed mb-8">
            {t.about.description2}
          </p>

          <div class="grid grid-cols-3 gap-6">
            {t.about.stats.map((stat, i) => (
              <div class="text-center p-4 border border-gris-borde hover:border-dorado transition-all duration-300 magnetic group" style={`transition-delay: ${i * 0.1}s`}>
                <span class="font-serif text-3xl font-bold text-dorado group-hover:scale-110 transition-transform duration-300 inline-block">{stat.number}</span>
                <p class="text-gris-claro text-sm mt-2">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="py-24 lg:py-32 bg-negro-suave">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        <div class="scroll-reveal p-10 lg:p-12 bg-negro border border-gris-borde hover:border-dorado transition-all duration-500 magnetic relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-br from-dorado/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10">
            <div class="w-14 h-14 border-2 border-dorado flex items-center justify-center mb-6 group-hover:rotate-12 transition-transform duration-300">
              <svg class="w-7 h-7 text-dorado" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <h3 class="font-serif text-3xl font-bold text-blanco mb-6 group-hover:text-dorado transition-colors">{t.about.mission}</h3>
            <div class="w-12 h-0.5 bg-dorado mb-6"></div>
            <p class="text-gris-claro leading-relaxed">{t.about.missionText}</p>
          </div>
          <div class="absolute bottom-0 left-0 w-0 h-0.5 bg-gradient-to-r from-dorado to-dorado-claro group-hover:w-full transition-all duration-700"></div>
        </div>

        <div class="scroll-reveal p-10 lg:p-12 bg-negro border border-gris-borde hover:border-dorado transition-all duration-500 magnetic relative overflow-hidden group" style="transition-delay: 0.2s;">
          <div class="absolute inset-0 bg-gradient-to-br from-dorado/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10">
            <div class="w-14 h-14 border-2 border-dorado flex items-center justify-center mb-6 group-hover:rotate-12 transition-transform duration-300">
              <svg class="w-7 h-7 text-dorado" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            </div>
            <h3 class="font-serif text-3xl font-bold text-blanco mb-6 group-hover:text-dorado transition-colors">{t.about.vision}</h3>
            <div class="w-12 h-0.5 bg-dorado mb-6"></div>
            <p class="text-gris-claro leading-relaxed">{t.about.visionText}</p>
          </div>
          <div class="absolute bottom-0 left-0 w-0 h-0.5 bg-gradient-to-r from-dorado to-dorado-claro group-hover:w-full transition-all duration-700"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-24 lg:py-32 bg-negro">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16 scroll-reveal">
        <span class="text-dorado text-sm tracking-widest uppercase font-medium">{t.about.teamTitle}</span>
        <h2 class="section-title mt-4 mb-6">
          {t.about.teamSubtitle} <span class="text-dorado italic">{t.about.teamHighlight}</span>
        </h2>
        <div class="divider-dorado mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
        {t.about.team.map((member, i) => (
          <div class="group scroll-reveal text-center" style={`transition-delay: ${i * 0.15}s`}>
            <div class="relative mb-6 mx-auto">
              <div class="w-40 h-40 mx-auto border-2 border-gris-borde group-hover:border-dorado transition-all duration-500 flex items-center justify-center bg-negro-suave relative overflow-hidden magnetic">
                <span class="font-serif text-4xl font-bold text-dorado/50 group-hover:text-dorado transition-all duration-500 group-hover:scale-110">
                  {member.initials}
                </span>
                <div class="absolute inset-0 bg-gradient-to-br from-dorado/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              </div>
              <div class="absolute bottom-0 right-0 w-8 h-8 border-r-2 border-b-2 border-dorado translate-x-2 translate-y-2 opacity-0 group-hover:opacity-100 transition-all duration-500"></div>
            </div>
            <h3 class="font-serif text-lg font-semibold text-blanco group-hover:text-dorado transition-colors duration-300">
              {member.name}
            </h3>
            <p class="text-gris-claro text-sm mt-1">
              {member.role}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Organizational Chart -->
  <section class="py-24 lg:py-32 bg-negro-suave">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16 scroll-reveal">
        <span class="text-dorado text-sm tracking-widest uppercase font-medium">{t.about.orgTitle}</span>
        <h2 class="section-title mt-4 mb-6">
          {t.about.orgSubtitle} <span class="text-dorado italic">{t.about.orgHighlight}</span>
        </h2>
        <div class="divider-dorado mx-auto"></div>
      </div>

      <div class="scroll-reveal">
        <div class="flex justify-center mb-8">
          <div class="px-8 py-4 border-2 border-dorado bg-negro text-center">
            <span class="font-serif text-lg font-semibold text-dorado">{t.about.orgBoard}</span>
          </div>
        </div>

        <div class="flex justify-center mb-4">
          <div class="w-px h-8 bg-dorado"></div>
        </div>

        <div class="flex justify-center mb-4">
          <div class="px-8 py-4 border border-gris-borde bg-negro text-center">
            <span class="font-serif text-lg font-semibold text-blanco">{t.about.orgManager}</span>
          </div>
        </div>

        <div class="flex justify-center mb-4">
          <div class="w-px h-8 bg-dorado"></div>
        </div>

        <div class="flex justify-center mb-4">
          <div class="w-2/3 h-px bg-gris-borde relative">
            <div class="absolute left-0 top-0 w-1/3 h-px bg-dorado"></div>
            <div class="absolute left-1/3 top-0 w-1/3 h-px bg-dorado"></div>
            <div class="absolute left-2/3 top-0 w-1/3 h-px bg-dorado"></div>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="scroll-reveal-left">
            <div class="flex justify-center mb-4">
              <div class="w-px h-8 bg-dorado"></div>
            </div>
            <div class="border border-gris-borde bg-negro p-6 text-center hover:border-dorado transition-colors duration-300">
              <span class="font-serif text-base font-semibold text-blanco block mb-3">{t.about.orgAdmin}</span>
              <ul class="space-y-1 text-gris-claro text-sm">
                {t.about.orgAdminItems.map(item => <li>{item}</li>)}
              </ul>
            </div>
          </div>

          <div class="scroll-reveal">
            <div class="flex justify-center mb-4">
              <div class="w-px h-8 bg-dorado"></div>
            </div>
            <div class="border border-gris-borde bg-negro p-6 text-center hover:border-dorado transition-colors duration-300">
              <span class="font-serif text-base font-semibold text-blanco block mb-3">{t.about.orgCommercial}</span>
              <ul class="space-y-1 text-gris-claro text-sm">
                {t.about.orgCommercialItems.map(item => <li>{item}</li>)}
              </ul>
            </div>
          </div>

          <div class="scroll-reveal-right">
            <div class="flex justify-center mb-4">
              <div class="w-px h-8 bg-dorado"></div>
            </div>
            <div class="border border-gris-borde bg-negro p-6 text-center hover:border-dorado transition-colors duration-300">
              <span class="font-serif text-base font-semibold text-blanco block mb-3">{t.about.orgOperations}</span>
              <ul class="space-y-1 text-gris-claro text-sm">
                {t.about.orgOperationsItems.map(item => <li>{item}</li>)}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer lang={lang as Language} />
</Layout>