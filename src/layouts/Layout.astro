---
import type { Language } from '../i18n/index.ts';
import { getTranslations } from '../i18n/index.ts';

interface Props {
  title: string;
  description?: string;
  lang?: Language;
}

const { title, description = "CONSTRUESCALA - Comprehensive solutions in finishes, remodeling, interior design and decoration", lang = 'es' } = Astro.props;
const t = getTranslations(lang);
---

<!DOCTYPE html>
<html lang={lang === 'es' ? 'es' : 'en'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#1a1a1a" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet" />
  <title>{title}</title>
</head>
<body class="min-h-screen">
  <!-- Page Loader -->
  <div id="page-loader" class="page-loader">
    <div class="loader-content">
      <svg class="loader-logo" viewBox="0 0 200 60" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path class="loader-path" d="M10 45 L50 15 L90 45 L130 15 L170 45" stroke="#c9a96e" stroke-width="2" fill="none"/>
        <path class="loader-path" d="M30 45 L70 15 L110 45 L150 15 L190 45" stroke="#c9a96e" stroke-width="1" fill="none" opacity="0.5"/>
      </svg>
      <div class="loader-text">CONSTRUESCALA</div>
      <div class="loader-bar">
        <div class="loader-progress"></div>
      </div>
    </div>
  </div>

  <!-- Page Transition Overlay -->
  <div id="page-transition" class="page-transition">
    <div class="transition-panel transition-panel-1"></div>
    <div class="transition-panel transition-panel-2"></div>
    <div class="transition-panel transition-panel-3"></div>
  </div>

  <slot />

  <script>
    import '../scripts/index.js';
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
