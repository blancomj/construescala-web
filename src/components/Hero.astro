---
---

<section class="relative h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Image with Parallax -->
  <div class="absolute inset-0 parallax-container">
    <img
      src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=1920&q=80&auto=format&fit=crop"
      alt="Interior de lujo"
      class="parallax-img w-full h-[120%] object-cover"
    />
    <!-- Overlay gradient -->
    <div class="absolute inset-0 bg-gradient-to-b from-negro/70 via-negro/50 to-negro"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
    <!-- Logo mark -->
    <div class="mb-8 opacity-0 animate-fade-in" style="animation-delay: 0.2s;">
      <div class="w-16 h-16 border-2 border-dorado mx-auto flex items-center justify-center">
        <span class="font-serif text-dorado text-3xl font-bold">C</span>
      </div>
    </div>

    <!-- Title with Clip-Path Reveal -->
    <h1 class="font-serif text-5xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl font-bold tracking-tight mb-6">
      <span class="inline-block animate-clip-reveal text-blanco">
        CONSTRU
      </span><br class="sm:hidden" /><span class="inline-block animate-clip-reveal text-dorado" style="animation-delay: 0.3s;">
        ESCALA
      </span>
    </h1>

    <!-- Decorative line -->
    <div class="flex justify-center mb-8">
      <div class="w-0 h-0.5 bg-dorado animate-line-expand"></div>
    </div>

    <!-- Subtitle -->
    <p class="font-serif text-xl sm:text-2xl md:text-3xl text-crema/90 italic mb-4 opacity-0 animate-fade-up" style="animation-delay: 0.8s;">
      Satisfacción & excelencia
    </p>

    <!-- Description -->
    <p class="text-gris-claro text-base sm:text-lg max-w-2xl mx-auto mb-10 opacity-0 animate-fade-up" style="animation-delay: 1s;">
      Soluciones integrales en acabados, remodelación, diseño y decoración de interiores
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0 animate-fade-up" style="animation-delay: 1.2s;">
      <a href="/portafolio" class="btn-dorado">
        Ver Proyectos
      </a>
      <a href="/contacto" class="btn-dorado-outline">
        Contáctanos
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0 animate-fade-in" style="animation-delay: 1.8s;">
    <div class="flex flex-col items-center gap-2">
      <span class="text-gris-claro text-xs tracking-widest uppercase">Scroll</span>
      <div class="w-px h-12 bg-gradient-to-b from-dorado to-transparent"></div>
    </div>
  </div>
</section>
