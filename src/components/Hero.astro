---
import type { Language } from '../i18n/index.ts';
import { getTranslations } from '../i18n/index.ts';

interface Props {
  lang?: Language;
}

const { lang = 'es' } = Astro.props;
const t = getTranslations(lang);
---

<section class="relative h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Image with Parallax -->
  <div class="absolute inset-0 parallax-container">
    <img
      src="/images/hero/hero-bg.jpg"
      alt={lang === 'es' ? 'Interior de lujo' : 'Luxury interior'}
      class="parallax-img w-full h-[120%] object-cover"
    />
    <!-- Overlay gradient -->
    <div class="absolute inset-0 bg-gradient-to-b from-negro/70 via-negro/50 to-negro"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
    <!-- Title with Clip-Path Reveal -->
    <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-bold tracking-tight mb-6">
      <span class="inline-block animate-clip-reveal text-blanco">
        CONSTRU
      </span><br class="sm:hidden" /><span class="inline-block animate-clip-reveal text-dorado" style="animation-delay: 0.3s;">
        ESCALA
      </span>
    </h1>

    <!-- Decorative line -->
    <div class="flex justify-center mb-8">
      <div class="w-0 h-0.5 bg-dorado animate-line-expand"></div>
    </div>

    <!-- Subtitle -->
    <p class="font-serif text-xl sm:text-2xl md:text-3xl text-crema/90 italic mb-4 opacity-0 animate-fade-up" style="animation-delay: 0.8s;">
      {t.hero.subtitle}
    </p>

    <!-- Description -->
    <p class="text-blanco/80 text-base sm:text-lg max-w-2xl mx-auto mb-10 opacity-0 animate-fade-up" style="animation-delay: 1s;">
      {t.hero.description}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0 animate-fade-up" style="animation-delay: 1.2s;">
      <a href={`/${lang}/portfolio`} class="btn-dorado">
        {t.hero.cta1}
      </a>
      <a href={`/${lang}/contact`} class="btn-dorado-outline">
        {t.hero.cta2}
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-16 left-1/2 -translate-x-1/2 opacity-0 animate-fade-in" style="animation-delay: 1.8s;">
    <div class="flex flex-col items-center gap-2">
      <span class="text-blanco/70 text-xs tracking-widest uppercase">{t.hero.scroll}</span>
      <div class="w-px h-12 bg-gradient-to-b from-dorado to-transparent animate-pulse"></div>
    </div>
  </div>

  <!-- Marquee Text -->
  <div class="absolute bottom-0 left-0 right-0 py-3 border-t border-gris-borde/30 overflow-hidden">
    <div class="marquee-content whitespace-nowrap text-blanco/50 text-xs tracking-[0.3em] uppercase font-serif">
      {lang === 'es' ? (
        <>
          <span>ARQUITECTURA</span><span class="mx-6 text-dorado/60">✦</span>
          <span>DISEÑO DE INTERIORES</span><span class="mx-6 text-dorado/60">✦</span>
          <span>REMODELACIÓN</span><span class="mx-6 text-dorado/60">✦</span>
          <span>DECORACIÓN</span><span class="mx-6 text-dorado/60">✦</span>
          <span>ACABADOS</span><span class="mx-6 text-dorado/60">✦</span>
          <span>ARQUITECTURA</span><span class="mx-6 text-dorado/60">✦</span>
          <span>DISEÑO DE INTERIORES</span><span class="mx-6 text-dorado/60">✦</span>
          <span>REMODELACIÓN</span><span class="mx-6 text-dorado/60">✦</span>
          <span>DECORACIÓN</span><span class="mx-6 text-dorado/60">✦</span>
          <span>ACABADOS</span><span class="mx-6 text-dorado/60">✦</span>
        </>
      ) : (
        <>
          <span>ARCHITECTURE</span><span class="mx-6 text-dorado/60">✦</span>
          <span>INTERIOR DESIGN</span><span class="mx-6 text-dorado/60">✦</span>
          <span>REMODELING</span><span class="mx-6 text-dorado/60">✦</span>
          <span>DECORATION</span><span class="mx-6 text-dorado/60">✦</span>
          <span>FINISHES</span><span class="mx-6 text-dorado/60">✦</span>
          <span>ARCHITECTURE</span><span class="mx-6 text-dorado/60">✦</span>
          <span>INTERIOR DESIGN</span><span class="mx-6 text-dorado/60">✦</span>
          <span>REMODELING</span><span class="mx-6 text-dorado/60">✦</span>
          <span>DECORATION</span><span class="mx-6 text-dorado/60">✦</span>
          <span>FINISHES</span><span class="mx-6 text-dorado/60">✦</span>
        </>
      )}
    </div>
  </div>
</section>
