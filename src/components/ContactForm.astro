---
import type { Language } from '../i18n/index.ts';
import { getTranslations } from '../i18n/index.ts';

interface Props {
  lang?: Language;
}

const { lang = 'es' } = Astro.props;
const t = getTranslations(lang);
---

<form id="contact-form" class="space-y-6">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="contact-name" class="block text-blanco text-sm mb-2">{t.contactPage.name} *</label>
      <input
        type="text"
        id="contact-name"
        name="name"
        required
        class="w-full px-4 py-3 bg-negro-suave border border-gris-borde text-blanco placeholder-gris-texto focus:border-dorado focus:outline-none transition-colors duration-300"
        placeholder={t.contactPage.name}
      />
    </div>
    <div>
      <label for="contact-phone" class="block text-blanco text-sm mb-2">{t.contactPage.phone}</label>
      <input
        type="tel"
        id="contact-phone"
        name="phone"
        class="w-full px-4 py-3 bg-negro-suave border border-gris-borde text-blanco placeholder-gris-texto focus:border-dorado focus:outline-none transition-colors duration-300"
        placeholder="+57 300 000 0000"
      />
    </div>
  </div>

  <div>
    <label for="contact-email" class="block text-blanco text-sm mb-2">{t.contactPage.email} *</label>
    <input
      type="email"
      id="contact-email"
      name="email"
      required
      class="w-full px-4 py-3 bg-negro-suave border border-gris-borde text-blanco placeholder-gris-texto focus:border-dorado focus:outline-none transition-colors duration-300"
      placeholder={lang === 'es' ? 'tu@email.com' : 'your@email.com'}
    />
  </div>

  <div>
    <label for="contact-service" class="block text-blanco text-sm mb-2">{t.contactPage.projectType} *</label>
    <select
      id="contact-service"
      name="service"
      required
      class="w-full px-4 py-3 bg-negro-suave border border-gris-borde text-blanco focus:border-dorado focus:outline-none transition-colors duration-300 appearance-none cursor-pointer"
    >
      {t.contactPage.projectOptions.map(option => (
        <option value={option.value}>{option.label}</option>
      ))}
    </select>
  </div>

  <div>
    <label for="contact-message" class="block text-blanco text-sm mb-2">{t.contactPage.message} *</label>
    <textarea
      id="contact-message"
      name="message"
      rows="5"
      required
      class="w-full px-4 py-3 bg-negro-suave border border-gris-borde text-blanco placeholder-gris-texto focus:border-dorado focus:outline-none transition-colors duration-300 resize-none"
      placeholder={t.contactPage.messagePlaceholder}
    ></textarea>
  </div>

  <button type="submit" class="btn-dorado w-full sm:w-auto">
    {t.contactPage.submit}
  </button>

  <p id="form-status" class="text-sm mt-4 hidden"></p>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    
    submitBtn.textContent = 'Sending...';
    submitBtn.disabled = true;
    
    if (status) {
      status.textContent = '';
      status.classList.add('hidden');
    }

    const data = Object.fromEntries(new FormData(form).entries());

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.reset();
        submitBtn.textContent = 'Message Sent!';
        submitBtn.classList.add('bg-green-600');
        
        if (status) {
          status.textContent = 'Message sent successfully!';
          status.classList.remove('hidden', 'text-red-500');
          status.classList.add('text-green-500');
        }
      } else {
        throw new Error('Error sending');
      }
    } catch (error) {
      submitBtn.textContent = 'Error. Try again';
      submitBtn.classList.add('bg-red-600');
      
      if (status) {
        status.textContent = 'Error sending message. Please try again.';
        status.classList.remove('hidden', 'text-green-500');
        status.classList.add('text-red-500');
      }
    }

    setTimeout(() => {
      submitBtn.textContent = originalText;
      submitBtn.classList.remove('bg-green-600', 'bg-red-600');
      submitBtn.disabled = false;
    }, 3000);
  });
</script>