---
import type { Language } from '../i18n/index.ts';
import { getTranslations, getLangFromUrl, getAlternateLangUrl } from '../i18n/index.ts';

interface Props {
  lang?: Language;
}

const { lang = 'es' } = Astro.props;
const t = getTranslations(lang);
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: `/${lang}/`, label: t.nav.home },
  { href: `/${lang}/about`, label: t.nav.about },
  { href: `/${lang}/services`, label: t.nav.services },
  { href: `/${lang}/portfolio`, label: t.nav.portfolio },
  { href: `/${lang}/contact`, label: t.nav.contact },
];

const alternateUrl = getAlternateLangUrl(Astro.url, lang);
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href={`/${lang}/`} class="flex items-center gap-3 group relative z-50">
        <div class="w-11 h-11 border-2 border-dorado flex items-center justify-center transition-all duration-500 group-hover:bg-dorado group-hover:rotate-45 logo-breathe">
          <span class="font-serif text-dorado text-xl font-bold group-hover:text-negro transition-all duration-500 group-hover:-rotate-45">C</span>
        </div>
        <div class="hidden sm:block">
          <span class="font-serif text-xl font-semibold tracking-wider text-blanco">CONSTRU</span><span class="font-serif text-xl font-semibold tracking-wider text-dorado">ESCALA</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1 nav-links-container" id="nav-links">
        <div class="nav-spotlight" id="nav-spotlight"></div>
        {navLinks.map(link => {
          const isActive = currentPath === link.href || (link.href !== `/${lang}/` && currentPath.startsWith(link.href));
          return (
            <a
              href={link.href}
              data-nav-link
              class={`relative px-5 py-2 text-sm tracking-widest uppercase font-medium transition-all duration-300 group nav-hover-line ${isActive ? 'text-dorado active' : 'text-blanco/80 hover:text-dorado'}`}
            >
              <span class="relative z-10">{link.label}</span>
            </a>
          );
        })}
      </div>

      <!-- Right Section -->
      <div class="hidden lg:flex items-center gap-4">
        <!-- Language Switcher -->
        <a
          href={alternateUrl}
          class="flex items-center gap-2 px-3 py-2 border border-gris-borde hover:border-dorado transition-all duration-300 group lang-flip"
          title={lang === 'es' ? 'English' : 'Español'}
        >
          {lang === 'es' ? (
            <img src="/images/flags/en.png" alt="EN" class="w-5 h-auto" />
          ) : (
            <img src="/images/flags/es.png" alt="ES" class="w-5 h-auto" />
          )}
        </a>

        <!-- CTA Button -->
        <a href={`/${lang}/contact`} class="relative px-6 py-2.5 bg-dorado text-negro font-semibold tracking-wider uppercase text-xs overflow-hidden group cta-shimmer">
          <span class="relative z-10 group-hover:text-negro transition-colors duration-300">{t.nav.cta}</span>
          <div class="absolute inset-0 bg-dorado-claro transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="menu-btn"
        class="lg:hidden relative w-10 h-10 flex items-center justify-center z-[60]"
        aria-label="Menu"
      >
        <div class="flex flex-col gap-[5px] w-6">
          <span class="block w-full h-[2px] bg-white transition-all duration-300 origin-center line-1"></span>
          <span class="block w-full h-[2px] bg-white transition-all duration-300 origin-center line-2"></span>
          <span class="block w-3/5 h-[2px] bg-white transition-all duration-300 origin-right line-3"></span>
        </div>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 mobile-menu-bg lg:hidden opacity-0 pointer-events-none transition-opacity duration-500"
  >
    <div class="flex flex-col items-center justify-center h-full gap-3">
      {navLinks.map((link, i) => (
        <a
          href={link.href}
          class="mobile-clip-reveal text-3xl md:text-4xl tracking-widest uppercase font-serif text-blanco hover:text-dorado transition-colors duration-300"
          style={`transition-delay: ${0.1 + i * 0.08}s`}
        >
          {link.label}
        </a>
      ))}

      <!-- Mobile Language Switcher -->
      <a
        href={alternateUrl}
        class="mt-8 flex items-center gap-3 px-6 py-3 border border-gris-borde hover:border-dorado transition-all duration-300 mobile-clip-reveal"
        style={`transition-delay: ${0.1 + navLinks.length * 0.08}s`}
      >
        {lang === 'es' ? (
          <img src="/images/flags/en-large.png" alt="EN" class="w-8 h-auto" />
        ) : (
          <img src="/images/flags/es-large.png" alt="ES" class="w-8 h-auto" />
        )}
        <span class="text-blanco text-sm tracking-wider uppercase">{lang === 'es' ? 'English' : 'Español'}</span>
      </a>

      <!-- Mobile CTA -->
      <a
        href={`/${lang}/contact`}
        class="mt-4 btn-dorado mobile-clip-reveal"
        style={`transition-delay: ${0.1 + (navLinks.length + 1) * 0.08}s`}
      >
        {t.nav.cta}
      </a>
    </div>
  </div>
</nav>

<style>
  /* Hamburger Animation */
  #menu-btn.active .line-1 {
    transform: rotate(45deg) translate(5px, 5px);
    background-color: #c9a96e;
  }

  #menu-btn.active .line-2 {
    opacity: 0;
    transform: scaleX(0);
  }

  #menu-btn.active .line-3 {
    width: 100%;
    transform: rotate(-45deg) translate(5px, -5px);
    background-color: #c9a96e;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileLinks = mobileMenu?.querySelectorAll('a');
    const navLinksContainer = document.getElementById('nav-links');
    const spotlight = document.getElementById('nav-spotlight');
    const navLinks = navLinksContainer?.querySelectorAll('[data-nav-link]');

    // Mobile menu toggle
    menuBtn?.addEventListener('click', () => {
      menuBtn.classList.toggle('active');
      mobileMenu?.classList.toggle('active');
      document.body.style.overflow = mobileMenu?.classList.contains('active') ? 'hidden' : '';
    });

    mobileLinks?.forEach(link => {
      link.addEventListener('click', () => {
        menuBtn?.classList.remove('active');
        mobileMenu?.classList.remove('active');
        document.body.style.overflow = '';
      });
    });

    // Nav spotlight effect
    if (navLinksContainer && spotlight && navLinks) {
      navLinksContainer.addEventListener('mousemove', (e) => {
        const target = e.target as HTMLElement;
        const navLink = target.closest('[data-nav-link]') as HTMLElement;
        
        if (navLink) {
          const containerRect = navLinksContainer.getBoundingClientRect();
          const linkRect = navLink.getBoundingClientRect();
          
          const left = linkRect.left - containerRect.left;
          const width = linkRect.width;
          
          spotlight.style.left = `${left}px`;
          spotlight.style.width = `${width}px`;
          spotlight.style.opacity = '1';
        }
      });

      navLinksContainer.addEventListener('mouseleave', () => {
        spotlight.style.opacity = '0';
      });
    }

    // Navbar scroll effect with glassmorphism
    const navbar = document.getElementById('navbar');
    let lastScroll = 0;
    
    window.addEventListener('scroll', () => {
      const currentScroll = window.scrollY;
      
      if (currentScroll > 50) {
        navbar?.classList.add('navbar-scrolled');
      } else {
        navbar?.classList.remove('navbar-scrolled');
      }
      
      lastScroll = currentScroll;
    });
  });
</script>
