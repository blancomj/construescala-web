---
const services = [
  {
    number: '01',
    title: 'Diseño Arquitectónico',
    description: 'Generamos propuestas e ideas para la creación y realización de espacios físicos, integrando factores geométricos-espaciales, higiénico-constructivos y estéticos formales.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
  },
  {
    number: '02',
    title: 'Madera & Ambientación',
    description: 'Desarrollamos e implementamos proyectos en madera con enfoque funcional y estético, ejecutando desde estructuras hasta acabados personalizados.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
  },
  {
    number: '03',
    title: 'Interiorismo',
    description: 'Ofrecemos servicios de diseño interior con enfoque técnico, acompañados de la ejecución integral del proyecto. Soluciones residenciales y comerciales.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>`,
  },
];
---

<section class="py-24 lg:py-32 bg-negro">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-20 scroll-reveal">
      <span class="text-dorado text-sm tracking-widest uppercase font-medium">Nuestros Servicios</span>
      <h2 class="section-title mt-4 mb-6">
        Transformamos <span class="text-dorado italic">espacios</span>
      </h2>
      <div class="divider-dorado mx-auto mb-6"></div>
      <p class="section-subtitle mx-auto">
        Ofrecemos soluciones integrales con los más altos estándares de calidad y eficiencia
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      {services.map((service, i) => (
        <div class="group scroll-reveal" style={`transition-delay: ${i * 0.15}s`}>
          <div class="p-8 lg:p-10 border border-gris-borde hover:border-dorado transition-all duration-500 h-full relative overflow-hidden">
            <!-- Hover background -->
            <div class="absolute inset-0 bg-gradient-to-br from-dorado/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <div class="relative z-10">
              <!-- Number -->
              <span class="text-dorado/30 font-serif text-6xl font-bold absolute -top-2 -right-2 group-hover:text-dorado/20 transition-colors duration-500">
                {service.number}
              </span>
              
              <!-- Icon -->
              <div class="text-dorado mb-6 transition-transform duration-300 group-hover:scale-110">
                <Fragment set:html={service.icon} />
              </div>

              <!-- Content -->
              <h3 class="font-serif text-2xl font-semibold text-blanco mb-4 group-hover:text-dorado transition-colors duration-300">
                {service.title}
              </h3>
              <p class="text-gris-claro text-sm leading-relaxed">
                {service.description}
              </p>
              
              <!-- Link -->
              <div class="mt-6">
                <a href="/servicios" class="text-dorado text-sm tracking-wider uppercase inline-flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0">
                  Más información
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
