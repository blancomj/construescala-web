---
import type { Language } from '../i18n/index.ts';
import { getTranslations } from '../i18n/index.ts';

interface Props {
  lang?: Language;
}

const { lang = 'es' } = Astro.props;
const t = getTranslations(lang);

const projectImages = [
  'https://images.unsplash.com/photo-1600210492493-0946911123ea?w=800&q=80&auto=format&fit=crop',
  'https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=800&q=80&auto=format&fit=crop',
  'https://images.unsplash.com/photo-1600607687644-c7171b42498f?w=800&q=80&auto=format&fit=crop',
];
---

<section class="py-24 lg:py-32 bg-negro-suave">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 scroll-reveal">
      <div>
        <span class="text-dorado text-sm tracking-widest uppercase font-medium">{t.projects.sectionTitle}</span>
        <h2 class="section-title mt-4 mb-6">
          {t.projects.heading} <span class="text-dorado italic">{t.projects.headingHighlight}</span>
        </h2>
        <div class="divider-dorado mb-6"></div>
      </div>
      <a href={lang === 'es' ? '/portafolio' : '/en/portfolio'} class="btn-dorado-outline text-xs self-start md:self-auto">
        {t.projects.viewAll}
      </a>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {t.projects.items.map((project, i) => (
        <a
          href={lang === 'es' ? '/portafolio' : '/en/portfolio'}
          class="group scroll-reveal block"
          style={`transition-delay: ${i * 0.2}s`}
        >
          <div class="img-overlay aspect-[4/5] overflow-hidden relative">
            <img
              src={projectImages[i]}
              alt={project.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <!-- Overlay gradient - enhanced -->
            <div class="absolute inset-0 bg-gradient-to-t from-negro/90 via-negro/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-500"></div>
            
            <!-- View Project Button - appears on hover -->
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500">
              <div class="w-16 h-16 border-2 border-dorado rounded-full flex items-center justify-center transform scale-0 group-hover:scale-100 transition-transform duration-500 delay-100">
                <svg class="w-6 h-6 text-dorado" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </div>
            </div>
          </div>
          <div class="p-6 bg-negro border border-t-0 border-gris-borde group-hover:border-dorado transition-all duration-500 relative overflow-hidden">
            <!-- Background glow -->
            <div class="absolute inset-0 bg-gradient-to-r from-dorado/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <div class="relative z-10">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-dorado text-xs tracking-wider uppercase font-medium">{project.category}</span>
                <span class="w-1 h-1 bg-gris-texto rounded-full"></span>
                <span class="text-gris-texto text-xs">{project.date}</span>
              </div>
              <h3 class="font-serif text-xl font-semibold text-blanco mb-2 group-hover:text-dorado transition-colors duration-300">
                {project.title}
              </h3>
              <p class="text-gris-claro text-sm flex items-center gap-2">
                <svg class="w-4 h-4 text-dorado" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                {project.location}
              </p>
            </div>
            
            <!-- Bottom line -->
            <div class="absolute bottom-0 left-0 w-0 h-0.5 bg-dorado group-hover:w-full transition-all duration-700"></div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
